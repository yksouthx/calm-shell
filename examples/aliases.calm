# A fuller alias set than the bundled defaults -- copy what you like into
# ~/.config/calm-shell/aliases.calm.

[aliases]
ll = "ls -la"
la = "ls -A"
l = "ls -CF"

gs = "git status"
ga = "git add"
gc = "git commit"
gp = "git push"
gl = "git log --oneline --graph --decorate"
gd = "git diff"

grep = "grep --color=auto"
df = "df -h"
du = "du -h"
mkdir = "mkdir -p"
