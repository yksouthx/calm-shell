# Example environment.calm — anything under [environment] becomes a real
# environment variable for every command calm-shell runs, not just
# calm-shell's own behavior. Copy this over
# ~/.config/calm-shell/environment.calm, or take individual lines.

[environment]
EDITOR = "code --wait"
PAGER = "less"
LANG = "en_US.UTF-8"
BROWSER = "firefox"
# Anything you'd normally put in .bashrc/.zshrc's `export` lines goes
# here the same way — no `export` keyword needed.
GOPATH = "~/go"
