# Maintainer: yksouthx <see https://github.com/s0uth09>
pkgname=calm-shell
pkgver=0.1.0
pkgrel=1
pkgdesc="A calm, pastel, Arch-native interactive shell for EndeavourOS"
arch=('x86_64' 'aarch64')
url="https://github.com/s0uth09/calm-shell"
license=('MIT')
depends=('glibc')
# calm-shell runs fine without either — `git status` is skipped silently
# (see src/git.c) and $EDITOR falls back to nano (see
# src/commands/config_cmd.c) — but both are needed for two headline
# features (prompt git integration, `calm config`) to actually do
# anything, so they're worth surfacing to installers rather than
# something the shell quietly does without.
optdepends=('git: prompt shows branch + clean/dirty status'
            'nano: fallback editor for `calm config` if $EDITOR is unset')
makedepends=('gcc' 'make')
provides=('calm')
conflicts=('calm-shell-git')
source=("$pkgname-$pkgver.tar.gz::https://github.com/s0uth09/calm-shell/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
	cd "$pkgname-$pkgver"
	make CFLAGS="-O2 -std=c11" all
}

check() {
	cd "$pkgname-$pkgver"
	make test
}

package() {
	cd "$pkgname-$pkgver"
	install -Dm0755 "calm" "$pkgdir/usr/bin/calm"
	install -Dm0644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
	install -Dm0644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
