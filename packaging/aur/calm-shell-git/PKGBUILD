# Maintainer: yksouthx <see https://github.com/s0uth09>
pkgname=calm-shell-git
pkgver=r1.0000000
pkgrel=1
pkgdesc="A calm, pastel, Arch-native interactive shell for EndeavourOS (git build)"
arch=('x86_64' 'aarch64')
url="https://github.com/s0uth09/calm-shell"
license=('MIT')
depends=('glibc')
# See packaging/aur/calm-shell/PKGBUILD for why these are opt- rather
# than hard depends: calm-shell degrades gracefully without either.
optdepends=('git: prompt shows branch + clean/dirty status'
            'nano: fallback editor for `calm config` if $EDITOR is unset')
makedepends=('gcc' 'make' 'git')
provides=('calm' 'calm-shell')
conflicts=('calm-shell' 'calm')
source=("$pkgname::git+https://github.com/s0uth09/calm-shell.git")
sha256sums=('SKIP')

pkgver() {
	cd "$pkgname"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "$pkgname"
	make CFLAGS="-O2 -std=c11" all
}

check() {
	cd "$pkgname"
	make test
}

package() {
	cd "$pkgname"
	install -Dm0755 "calm" "$pkgdir/usr/bin/calm"
	install -Dm0644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
	install -Dm0644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}
